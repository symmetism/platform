# --- Python (Stack SoT S1: Python ≥3.11 with uv) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# --- Virtual environments / package managers ---
.venv/
venv/
env/

# --- Test / coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.cache/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Build artifacts ---
*.tar
*.tar.gz

# --- Local environment / secrets (R3: never tracked) ---
.env
.env.*
!.env.example
*.key
*.pem
secret*.toml
secrets/
